// ============================================================================
// INPUT SPECIFICATION
// ============================================================================

/*
 * Your program receives a JSON object via STDIN:
 *
 * {
 *   "race_id": "TEST_001",
 *   "race_config": {
 *     "track": "Monza",
 *     "total_laps": 53,
 *     "base_lap_time": 82.5,
 *     "pit_lane_time": 22.0,
 *     "track_temp": 32
 *   },
 *   "strategies": {
 *     "pos1": {
 *       "driver_id": "D001",
 *       "starting_tire": "SOFT",
 *       "pit_stops": [
 *         {"lap": 18, "from_tire": "SOFT", "to_tire": "MEDIUM"}
 *       ]
 *     },
 *     "pos2": {
 *       "driver_id": "D002",
 *       "starting_tire": "MEDIUM",
 *       "pit_stops": [
 *         {"lap": 26, "from_tire": "MEDIUM", "to_tire": "HARD"}
 *       ]
 *     }
 *     // ... pos3 through pos20 (20 drivers total)
 *   }
 * }
 */

// ============================================================================
// OUTPUT SPECIFICATION
// ============================================================================

/*
 * Your program must output a JSON object to STDOUT:
 *
 * {
 *   "race_id": "TEST_001",
 *   "finishing_positions": [
 *     "D007", "D015", "D003", "D012", "D008",
 *     "D001", "D011", "D019", "D005", "D014",
 *     "D020", "D004", "D009", "D018", "D006",
 *     "D013", "D017", "D010", "D016", "D002"
 *   ]
 * }
 *
 * The finishing_positions array must contain exactly 20 driver IDs,
 * ordered from 1st place to 20th place.
 */

// ============================================================================
// HIGH-LEVEL APPROACH
// ============================================================================

/*
 * Your task is to predict the finishing positions by simulating the race.
 *
 * Steps to consider:
 * 1. Read and parse the JSON input from STDIN
 * 2. Simulate the race to determine finishing order
 * 3. Output the results as JSON to STDOUT
 *
 * Your challenge is to discover how to accurately simulate the race by
 * analyzing the 30,000 historical races provided in data/historical_races/
 *
 * Key questions to answer through data analysis:
 * - How do different tire compounds affect performance?
 * - How do tires behave as they age?
 * - What role does track temperature play?
 * - How should pit stops be factored into the simulation?
 *
 * Practical model shape to start with:
 * lap_time = base_lap_time
 *          + compound_offset[tire]
 *          + a[tire] * tire_age
 *          + b[tire] * tire_age^2
 *          + c[tire] * (track_temp - ref_temp)
 *
 * Then tune parameters on historical races by comparing predicted finishing
 * order vs actual order.
 *
 * See PROBLEM_STATEMENT.md and docs/regulations.md for more details.
 */

// ============================================================================
// IMPLEMENTATION
// ============================================================================

FUNCTION main():
    // Read input from STDIN
    input_json = READ_FROM_STDIN()
    test_case = PARSE_JSON(input_json)

    // TODO: Implement your race simulation logic here
    // Analyze historical data to understand the race mechanics
    // Build a model that predicts finishing positions

    finishing_positions = YOUR_SIMULATION_LOGIC(test_case)

    // Prepare output
    output = {
        race_id: test_case.race_id,
        finishing_positions: finishing_positions
    }

    // Write output to STDOUT
    output_json = TO_JSON(output)
    WRITE_TO_STDOUT(output_json)
END FUNCTION

EXECUTE main()

// Optional: calibration mode (offline tuning)
FUNCTION calibrate_model():
    historical_races = LOAD_HISTORICAL_RACES("data/historical_races/")

    params = INITIAL_GUESS()
    best_params = OPTIMIZE(params) TO_MAXIMIZE ranking_score(predicted_order, actual_order)

    WRITE_PARAMS_INTO_SIMULATOR(best_params)
END FUNCTION

// ============================================================================
// TESTING
// ============================================================================

/*
 * Test your implementation:
 *
 * Single test case:
 *   cat data/test_cases/inputs/test_001.json | your_program
 *
 * All test cases:
 *   ./test_runner.sh
 *
 * The test runner will automatically read your command from
 * solution/run_command.txt and test your solution against all 100 test cases.
 *
 * Important off-by-one checks to validate manually:
 * - Is tire age incremented before or after lap-time calculation?
 * - Does a pit on lap L happen before timing lap L, or after finishing lap L?
 *
 * In this project, regulations indicate:
 * - first lap on fresh tires runs at age 1
 * - pit stop occurs at the end of the configured lap
 */
